# ── Anthropic (AI coach) ──────────────────────────────────────────────────────
# console.anthropic.com → API Keys
# Client-side key (used directly in browser during local dev)
VITE_ANTHROPIC_KEY=sk-ant-your-key-here
# Server-side key (used by /api/chat proxy in production — same value, no VITE_ prefix)
ANTHROPIC_KEY=sk-ant-your-key-here

# ── Strava ────────────────────────────────────────────────────────────────────
# strava.com/settings/api → set Authorization Callback Domain to: localhost
VITE_STRAVA_CLIENT_ID=your-strava-client-id
VITE_STRAVA_CLIENT_SECRET=your-strava-client-secret

# ── Supabase ──────────────────────────────────────────────────────────────────
# supabase.com → project → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...anon-key...
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...service-role-key...

# ── Composio ──────────────────────────────────────────────────────────────────
# 1. app.composio.dev → Settings → API Keys (copy the key)
COMPOSIO_API_KEY=your-composio-api-key
# 2. Choose any string for webhook signing — paste the same value into Composio's
#    Webhook secret field (under Settings → Webhooks).
COMPOSIO_WEBHOOK_SECRET=your-webhook-secret
# 3. For each app you want to connect, create an Auth Config in Composio:
#    app.composio.dev → Auth Configs → New → pick the app → save → copy the ID (ac_...)
COMPOSIO_AUTH_CONFIG_GARMIN=ac_your-garmin-auth-config-id
COMPOSIO_AUTH_CONFIG_OURA=ac_your-oura-auth-config-id
COMPOSIO_AUTH_CONFIG_WHOOP=ac_your-whoop-auth-config-id
