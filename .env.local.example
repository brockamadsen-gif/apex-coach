# ── Anthropic (AI coach) ──────────────────────────────────────────────────────
# console.anthropic.com → API Keys
# Client-side key (used directly in browser during local dev)
VITE_ANTHROPIC_KEY=sk-ant-your-key-here
# Server-side key (used by /api/chat proxy in production — same value, no VITE_ prefix)
ANTHROPIC_KEY=sk-ant-your-key-here

# ── Strava ────────────────────────────────────────────────────────────────────
# strava.com/settings/api → set Authorization Callback Domain to: localhost
VITE_STRAVA_CLIENT_ID=your-strava-client-id
VITE_STRAVA_CLIENT_SECRET=your-strava-client-secret

# ── Supabase ──────────────────────────────────────────────────────────────────
# supabase.com → project → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...anon-key...
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...service-role-key...

# ── Composio ──────────────────────────────────────────────────────────────────
# app.composio.dev → Settings → API Keys
COMPOSIO_API_KEY=your-composio-api-key
# Choose any string — paste it into Composio's webhook secret field too
COMPOSIO_WEBHOOK_SECRET=your-webhook-secret
