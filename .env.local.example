# Anthropic (required for AI coach)
VITE_ANTHROPIC_KEY=sk-ant-your-key-here

# Strava (required for live run data)
# Register your app at https://www.strava.com/settings/api
# Set "Authorization Callback Domain" to: localhost
VITE_STRAVA_CLIENT_ID=your-strava-client-id
VITE_STRAVA_CLIENT_SECRET=your-strava-client-secret
